    "nanoid": "^5.1.15",
    "next": "^15.5.19",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "recharts": "^3.9.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
